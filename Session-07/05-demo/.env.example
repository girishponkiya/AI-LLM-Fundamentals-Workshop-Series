# ── Session 7 demo environment ───────────────────────────────────────────────
# Copy this file to `.env` in 05-demo/. The notebooks call load_dotenv() automatically.
# Matches the OpenAI-compatible convention used across the Session 4–6 demos.

# ── Model backend (OpenAI-compatible: vLLM, Ollama, etc.) ─────────────────────
# vLLM example:    OPENAI_BASE_URL=http://<your-vllm-host>:8000/v1
# Ollama example:  OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=your-api-key-here           # any non-empty string for local servers
MODEL=your-tool-capable-model              # MUST support tool/function calling + structured output

# Embeddings backend for demo_03 (retrieval). Ollama: nomic-embed-text / bge-m3.
EMBED_MODEL=nomic-embed-text:latest

# ── MLflow tracing (your self-hosted server) ─────────────────────────────────
MLFLOW_TRACKING_URI=http://127.0.0.1:5001
MLFLOW_TRACKING_USERNAME=your-username
MLFLOW_TRACKING_PASSWORD=your-password
MLFLOW_EXPERIMENT=session7-app-dev

MLFLOW_TRACKING_INSECURE_TLS=true

# Workspace / tenant identifier for the MLflow deployment (if your server requires one).
MLFLOW_WORKSPACE=your-workspace

# ── Demo toggle ──────────────────────────────────────────────────────────────
# Set to 1 to run every notebook against a fake model (no live LLM needed) — use
# this to rehearse the flow / verify wiring before the session. Set to 0 for live.
USE_TEST_MODEL=0
